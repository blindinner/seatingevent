# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AllPay (for payments)
ALLPAY_LOGIN=your-allpay-login
ALLPAY_API_KEY=your-allpay-api-key
ALLPAY_TEST_MODE=true

# App URL (used for webhooks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps (for location autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Resend (for ticket emails)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=tickets@yourdomain.com
EMAIL_FROM_NAME=Your Event Platform
